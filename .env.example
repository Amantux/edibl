# Edibl — standalone (Docker) configuration.
#
# This file is for running Edibl on your OWN — `docker compose up` reads it as
# `.env` (copy this to `.env` and edit). Running the Home Assistant ADD-ON
# instead? Don't use this file — set the same options in the add-on's
# **Configuration** tab (they map to these env vars for you), and the app's
# Settings page can override the assistant/myMeal values at runtime.
#
# Every value is optional except EDIBL_SECRET_KEY. Blank = the built-in default.

# ── Core ────────────────────────────────────────────────────────────────────
# REQUIRED (standalone): a long random string. `openssl rand -base64 48`.
# The add-on generates/persists this for you, so it's not an add-on option.
EDIBL_SECRET_KEY=
# Where the SQLite DB + uploads live (a Docker volume in compose).
EDIBL_DATA_DIR=/data
# Override the database entirely (e.g. Postgres). Blank = SQLite in DATA_DIR.
EDIBL_DATABASE_URL=

# ── Auth (this is the standalone vs ingress split) ───────────────────────────
# STANDALONE: keep auth ON (false) — Edibl serves its own login.
# BEHIND HOME ASSISTANT INGRESS: the add-on sets this true, because HA has
# already authenticated the user upstream and proxies in. Do NOT set true unless
# something in front of Edibl authenticates for you.
EDIBL_DISABLE_AUTH=false
# Trusted reverse-proxy hops for client-IP / rate-limiting. 0 standalone; the
# add-on sets 1 (the Supervisor ingress proxy). Set to your proxy depth.
EDIBL_PROXY_HOPS=0
EDIBL_ALLOW_REGISTRATION=true
EDIBL_MIN_PASSWORD_LENGTH=8
EDIBL_JWT_HOURS=72
EDIBL_RATELIMIT_ENABLED=true
# Comma-separated allowed CORS origins (only needed if a separate web origin
# calls the API). Ingress does not need this.
EDIBL_CORS_ORIGINS=

# ── Assistant / LLM ──────────────────────────────────────────────────────────
# ollama | openai | anthropic | homeassistant | "" (chat disabled).
# NOTE: the app's Settings page can override all of these at runtime (stored per
# household in the DB); the effective value is UI-override > this env > default.
EDIBL_LLM_PROVIDER=
EDIBL_LLM_BASE_URL=
EDIBL_LLM_API_KEY=
EDIBL_LLM_MODEL=
# Only for provider=homeassistant: which HA conversation agent to target
# (e.g. conversation.ollama). Blank = HA's default agent.
EDIBL_LLM_AGENT_ID=
EDIBL_LLM_TIMEOUT=60
EDIBL_LLM_MAX_STEPS=6
# Look up unknown barcodes against a public product database.
EDIBL_BARCODE_LOOKUP=false
# Max receipt-photo / upload size, MB.
EDIBL_MAX_UPLOAD_MB=25

# ── Sibling apps (optional; the add-on auto-discovers myMeal) ─────────────────
EDIBL_MYMEAL_URL=
EDIBL_MYMEAL_TOKEN=
EDIBL_HOMEHOARD_URL=
EDIBL_HOMEHOARD_TOKEN=

# ── MCP server (AI tooling for HA Assist / other agents) ─────────────────────
EDIBL_MCP_ENABLED=true
# Bearer token clients must present. REQUIRED before exposing the MCP port to a
# network; blank = unauthenticated (only safe on a trusted/loopback network).
EDIBL_MCP_SERVER_TOKEN=
# Bind address for the MCP port in compose (127.0.0.1 = loopback only).
EDIBL_MCP_BIND=127.0.0.1
